# ─────────────────────────────────────────────────────────────
# KaonA-Agri — Environment Variables
# คัดลอกไฟล์นี้เป็น .env.local สำหรับ local dev
# ตั้งค่าทุก variable ใน Vercel Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Supabase (จำเป็น) ─────────────────────────────────────────
# หา URL และ Anon Key ได้ที่ Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (server-side only — ห้าม prefix NEXT_PUBLIC_)
# หาได้ที่ Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alias รองรับ Vercel Supabase Integration (ใส่ค่าเดียวกับ SERVICE_ROLE_KEY)
SUPABASE_SECRET_KEY=

# ── LINE LIFF (จำเป็น) ────────────────────────────────────────
# หา LIFF ID ได้ที่ LINE Developers Console → LIFF → ดูที่ LIFF ID
NEXT_PUBLIC_LIFF_ID=1234567890-xxxxxxxx

# LINE Channel ID (ตัวเลข เช่น 1234567890)
# หาได้ที่ LINE Developers Console → Basic settings → Channel ID
LINE_CHANNEL_ID=1234567890
NEXT_PUBLIC_LINE_CHANNEL_ID=1234567890

# ── Admin Web Login (จำเป็น) ──────────────────────────────────
# รหัสผ่านสำหรับ Admin Web (/admin-login)
ADMIN_WEB_EMAIL=admin@kaona.com
ADMIN_WEB_PASSWORD=เปลี่ยนรหัสผ่านนี้ก่อนใช้งานจริง

# ── Google Maps (แนะนำ — ใช้แสดงแผนที่แปลง) ──────────────────
# สร้าง API Key ได้ที่ Google Cloud Console → Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Supabase Storage (ใช้สำหรับอัปโหลดรูป) ───────────────────
# ชื่อ bucket สำหรับรูป GPS evidence (ค่า default: evidence)
NEXT_PUBLIC_SUPABASE_EVIDENCE_BUCKET=evidence

# ── Google Document AI / OCR (ต้องการถ้าใช้ OCR บัตรประชาชน) ──
# สร้าง Service Account ได้ที่ Google Cloud Console → IAM
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_DOCUMENTAI_PROCESSOR_ID=your-processor-id
GOOGLE_DOCUMENTAI_LOCATION=us
GOOGLE_DOCUMENTAI_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Private key: คัดลอก PEM ทั้งบรรทัด รวม \n
GOOGLE_DOCUMENTAI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Gemini API (ต้องการถ้าใช้ AI features) ────────────────────
# สร้าง API Key ได้ที่ https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ── Dev Only (ห้ามใส่ใน Production) ──────────────────────────
# ตั้งเป็น "true" เพื่อ bypass LINE login ขณะ dev บน localhost
NEXT_PUBLIC_DEV_BYPASS_LINE=
